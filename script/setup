#!/usr/bin/env python3
import argparse
import subprocess
import venv
import sys
from pathlib import Path

# --- Paths ---
_DIR = Path(__file__).parent
_PROGRAM_DIR = _DIR.parent
_VENV_DIR = _PROGRAM_DIR / ".venv"

parser = argparse.ArgumentParser(description="Set up venv for Wyoming Vosk (CPU optimized)")
parser.add_argument("--dev", action="store_true", help="Install dev requirements")
args = parser.parse_args()

print(f"Creating virtual environment in {_VENV_DIR}...")
builder = venv.EnvBuilder(with_pip=True, upgrade_deps=True)
context = builder.ensure_directories(_VENV_DIR)
builder.create(_VENV_DIR)

pip_exe = context.env_exe
pip_cmd = [pip_exe, "-m", "pip"]

# --- 1. Install Torch CPU first ---
# This prevents installing huge CUDA binaries
print("Installing Torch (CPU version)...")
subprocess.check_call(pip_cmd + [
    "install", 
    "torch", 
    "--index-url", "https://download.pytorch.org/whl/cpu"
])

# --- 2. Install requirements.txt ---
requirements_file = _PROGRAM_DIR / "requirements.txt"
if requirements_file.exists():
    print(f"Installing dependencies from {requirements_file}...")
    subprocess.check_call(pip_cmd + ["install", "-r", str(requirements_file)])
else:
    print(f"Error: {requirements_file} not found")
    sys.exit(1)

if args.dev:
    dev_file = _PROGRAM_DIR / "requirements_dev.txt"
    if dev_file.exists():
        subprocess.check_call(pip_cmd + ["install", "-r", str(dev_file)])

print("\nInstallation complete!")
print(f"To run the server, use: python3 {_DIR / 'run'}")
