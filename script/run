#!/usr/bin/env python3
import subprocess
import sys
import venv
from pathlib import Path

_DIR = Path(__file__).parent
_PROGRAM_DIR = _DIR.parent
_VENV_DIR = _PROGRAM_DIR / ".venv"

# Ensure venv exists
if not _VENV_DIR.exists():
    print(f"Error: Virtual environment not found. Run setup first.")
    sys.exit(1)

# Get python exe from venv
context = venv.EnvBuilder().ensure_directories(_VENV_DIR)
python_exe = context.env_exe

# --- Build Command ---
# We run the package using 'python -m <folder_name>' 
# Assuming your project folder is named 'wyoming_vosk'
command = [python_exe, "-m", "wyoming_vosk"]

if len(sys.argv) > 1:
    command.extend(sys.argv[1:])
else:
    # Default parameters
    command.extend([
        "--uri", "tcp://0.0.0.0:10205",
        "--speech-rate", "1.0"
    ])

print(f"Starting server: {' '.join(command)}")

try:
    process = subprocess.Popen(command, cwd=_PROGRAM_DIR)
    process.wait()
except KeyboardInterrupt:
    print("\nServer stopped.")
except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)